{
  "schemaVersion": 1,
  "id": "milkrust-sample-pack",
  "name": "MilkRust Sample Pack",
  "version": "0.1.0",
  "author": "MilkRust",
  "description": "Small local fixture pack for CLI, SDK, player, and Studio integration tests.",
  "license": "CC0-1.0",
  "requiredMilkRustVersion": "0.1.0",
  "sourceUrls": [
    "https://github.com/snapetech/MilkRust"
  ],
  "presets": [
    {
      "id": "warm-scope",
      "title": "Warm Scope",
      "file": "presets/warm-scope.milk",
      "sourceFormat": "milk",
      "tags": [
        "scope",
        "geometry",
        "fixture"
      ],
      "thumbnail": "thumbnails/warm-scope.png"
    },
    {
      "id": "blue-shape",
      "title": "Blue Shape",
      "file": "presets/blue-shape.milk",
      "sourceFormat": "milk",
      "tags": [
        "shape",
        "fixture"
      ],
      "thumbnail": ""
    }
  ],
  "textures": [],
  "fragments": [
    {
      "id": "center-polygon",
      "kind": "shape",
      "file": "fragments/center-polygon.json",
      "tags": [
        "shape"
      ]
    }
  ],
  "plugins": [
    {
      "id": "default-playlist",
      "kind": "data",
      "entry": "plugins/default-playlist.json"
    }
  ],
  "playlist": [
    "warm-scope",
    "blue-shape"
  ],
  "automationDefaults": {
    "transitionSeconds": 8,
    "randomizeOnBeat": false
  }
}
