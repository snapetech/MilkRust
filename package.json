{
  "name": "@milkrust/web",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./packages/milkrust-web/src/milkrustEngine.js",
  "types": "./packages/milkrust-web/src/milkrustEngine.d.ts",
  "exports": {
    ".": "./packages/milkrust-web/src/milkrustEngine.js"
  },
  "files": [
    "packages/milkrust-web/src/milkrustEngine.js",
    "packages/milkrust-web/src/milkrustEngine.d.ts",
    "pkg",
    "README.md",
    "LICENSE",
    "LICENSE-SCOPE.md"
  ],
  "scripts": {
    "build:wasm": "bash ./tools/build-wasm-package.sh",
    "check:council": "bash ./scripts/run-bug-council-all-phases.sh",
    "cli": "cargo run -p milkrust-cli --",
    "compliance:audit": "node ./tools/audit-milkrust-compliance.mjs",
    "compliance:ci": "npm run compliance:audit",
    "content:audit": "node ./tools/audit-milkrust-content-sources.mjs --write . ../slskdn ../slskR",
    "content:pull-community": "node ./tools/pull-milkrust-community-content.mjs",
    "content:report-community": "node ./tools/report-milkrust-community-packs.mjs --write",
    "content:report-community:compat": "node ./tools/report-milkrust-community-packs.mjs --write --compat --limit=25",
    "content:report-community:compat:full": "node ./tools/report-milkrust-community-packs.mjs --write --compat",
    "content:validate": "node ./tools/validate-milkrust-content-catalog.mjs",
    "pack:validate": "cargo run -p milkrust-cli -- pack-validate examples/sample-pack",
    "dev:player": "node ./tools/serve-milkrust-app.mjs player",
    "dev:studio": "node ./tools/serve-milkrust-app.mjs studio",
    "test:rust": "cargo test --workspace",
    "test:all": "cargo test --workspace && npm run test:web && npm run test:apps && npm run test:desktop && npm run pack:validate && npm run content:validate",
    "test:compatibility": "node ./tools/report-milkrust-compatibility.mjs",
    "test:performance": "node ./tools/measure-milkrust-performance.mjs",
    "test:apps": "node ./tools/smoke-milkrust-apps.mjs",
    "test:desktop": "cargo run -p milkrust-desktop --bin milkrust-desktop -- --preset examples/sample-pack/presets/warm-scope.milk --frames 4 --fps 30 --json",
    "desktop:player": "cargo run -p milkrust-desktop --bin player -- --pack examples/sample-pack --frames 4 --fps 30 --json",
    "desktop:studio": "cargo run -p milkrust-desktop --bin studio -- --pack examples/sample-pack --json",
    "test:web": "node --test packages/milkrust-web/src/*.test.js packages/milkrust-react/src/*.test.js",
    "test:react": "node --test packages/milkrust-react/src/*.test.js",
    "test:smoke": "node ./tools/smoke-milkrust.mjs",
    "desktop:probe": "cargo run -p milkrust-desktop --bin milkrust-desktop -- --help",
    "desktop:probe:ci": "cargo run -p milkrust-desktop --bin milkrust-desktop -- --preset examples/sample-pack/presets/warm-scope.milk --frames 4 --fps 30 --json",
    "desktop:player:ci": "cargo run -p milkrust-desktop --bin player -- --pack examples/sample-pack --frames 4 --fps 30",
    "desktop:studio:ci": "cargo run -p milkrust-desktop --bin studio -- --pack examples/sample-pack --json",
    "dev:web-component": "node ./tools/serve-milkrust-app.mjs web-component",
    "desktop:plugin-report": "node ./tools/report-milkrust-desktop-plugin-discovery.mjs",
    "desktop:plugin-report:catalog": "node ./tools/report-milkrust-desktop-plugin-discovery.mjs --catalog --include-community --include-no-assertion --write-markdown",
    "desktop:plugin-report:ci": "node ./tools/report-milkrust-desktop-plugin-discovery.mjs --pack examples/sample-pack --frames 4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
